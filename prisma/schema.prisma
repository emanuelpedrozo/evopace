generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  age          Int
  weight       Float
  height       Int
  sex          String
  goal         String
  level        String
  role         String   @default("Aluno")
  restrictions String?
  experience   String?
  sleep        Float    @default(7)
  fatigue      Int      @default(4)
  soreness     Int      @default(4)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessments       BodyAssessment[]
  runs              Run[]
  workoutPlans      WorkoutPlan[]
  trainingCycles    TrainingCycle[]
  workoutExecutions WorkoutExecution[]
  workouts          Workout[]

  @@map("users")
}

model Workout {
  id             String   @id @default(uuid())
  userId         String
  trainingPlanId String?
  planDayCode    String?
  planDayName    String?
  name           String
  split          String
  focus          String
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  exercises    WorkoutExercise[]
  executions   WorkoutExecution[]
  trainingPlan WorkoutPlan?      @relation(fields: [trainingPlanId], references: [id], onDelete: SetNull)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([trainingPlanId])
  @@map("workouts")
}

model WorkoutPlan {
  id        String   @id @default(uuid())
  userId    String
  name      String
  split     String
  goal      String
  startDate DateTime
  endDate   DateTime?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workouts Workout[]

  @@index([userId])
  @@map("workout_plans")
}

model WorkoutExercise {
  id               String   @id @default(uuid())
  workoutId        String
  name             String
  video            String?
  instruction      String
  targetMuscle     String
  secondaryMuscles String?
  equipment        String
  difficulty       String
  sets             Int
  reps             String
  load             Float
  restSeconds      Int
  rpe              Int
  order            Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  setExecutions WorkoutSetExecution[]
  workout       Workout               @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@index([workoutId])
  @@map("workout_exercises")
}

model WorkoutExecution {
  id         String    @id @default(uuid())
  userId     String
  workoutId  String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  setExecutions WorkoutSetExecution[]
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout       Workout               @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workoutId])
  @@map("workout_executions")
}

model WorkoutSetExecution {
  id          String   @id @default(uuid())
  executionId String
  exerciseId  String
  setNumber   Int
  reps        Int
  load        Float
  rpe         Int
  rir         Int?
  failed      Boolean  @default(false)
  completed   Boolean  @default(true)
  createdAt   DateTime @default(now())

  execution WorkoutExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  exercise  WorkoutExercise  @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@index([exerciseId])
  @@map("workout_set_executions")
}

model Run {
  id          String   @id @default(uuid())
  userId      String
  date        DateTime @default(now())
  type        String
  distance    Float
  timeMinutes Float
  paceSeconds Int
  elevation   Float
  avgHr       Int
  maxHr       Int
  cadence     Int
  effort      Int
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@map("runs")
}

model BodyAssessment {
  id         String   @id @default(uuid())
  userId     String
  date       DateTime @default(now())
  weight     Float
  bodyFat    Float
  muscleMass Float
  waist      Float
  chest      Float
  thigh      Float
  vo2        Float
  restingHr  Int
  photoFront String?
  photoSide  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@map("body_assessments")
}

model TrainingCycle {
  id        String   @id @default(uuid())
  userId    String
  type      String
  name      String
  objective String
  startsAt  DateTime
  endsAt    DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("training_cycles")
}
